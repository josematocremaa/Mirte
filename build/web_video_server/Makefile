	$(MAKE) $(MAKESILENT) -f CMakeFiles/web_video_server_node.dir/build.make CMakeFiles/web_video_server_node.dir/src/web_video_server_node.cpp.i
.PHONY : src/web_video_server_node.cpp.i

src/web_video_server_node.s: src/web_video_server_node.cpp.s
.PHONY : src/web_video_server_node.s

# target to generate assembly for a file
src/web_video_server_node.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/web_video_server_node.dir/build.make CMakeFiles/web_video_server_node.dir/src/web_video_server_node.cpp.s
.PHONY : src/web_video_server_node.cpp.s

